@page "/assessments"
@attribute [Authorize(Roles = "Admin,Consultant,ClientRespondent")]
@inject AssessmentsClient AssessmentsClient
@inject OrgsClient OrgsClient
@inject QuestionnaireClient QuestionnaireClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Assessments</PageTitle>

<h1 class="page-title">Assessments</h1>

<div class="toolbar-row">
    <label class="field-inline">Year <input type="number" @bind="_yearFilter" /></label>
    <label class="field-inline">Status <input @bind="_statusFilter" /></label>
    <button class="btn btn-secondary" @onclick="ReloadAsync">Refresh</button>
</div>

<div class="create-form">
    <h3 class="section-title">Create Assessment</h3>
    <div class="field-grid">
        <label>Name <input @bind="_create.Name" /></label>
        <label>Year <input type="number" @bind="_create.AssessmentYear" /></label>
        <label>
            Organization
            <select @bind="_create.OrgIdText" disabled="@_localMode">
                <option value="">Select organization</option>
                @foreach (var org in _orgOptions)
                {
                    <option value="@org.Id">@org.Name (@org.Id)</option>
                }
            </select>
        </label>
        <label>
            Questionnaire
            <select @bind="_create.QuestionnaireIdText" disabled="@_localMode">
                <option value="">Select questionnaire</option>
                @foreach (var questionnaire in _questionnaireOptions)
                {
                    <option value="@questionnaire.Id">@questionnaire.Name (@questionnaire.Version)</option>
                }
            </select>
        </label>
    </div>
    @if (_localMode)
    {
        <p class="hint-text">Local demo mode is active. Organization and Questionnaire IDs are auto-generated.</p>
    }
    <button type="button" class="btn btn-primary" @onclick="CreateAsync">Create Assessment</button>
</div>

<Toast Message="@_toast" Type="@_toastType" />

<table class="app-table">
    <thead>
    <tr><th>Name</th><th>Year</th><th>Status</th><th>Last Updated</th><th>Actions</th></tr>
    </thead>
    <tbody>
    @foreach (var item in Filtered)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.AssessmentYear</td>
            <td>@item.Status</td>
            <td>@item.CreatedAt.ToLocalTime()</td>
            <td>
                @if (_canReview)
                {
                    <button class="btn btn-secondary" @onclick="() => GoReview(item.Id)">Review</button>
                }
                @if (_canDashboard)
                {
                    <button class="btn btn-secondary" @onclick="() => GoDashboard(item.Id)">Dashboard</button>
                }
                @if (_canCollect)
                {
                    <button class="btn btn-secondary" @onclick="() => GoCollect(item.Id)">Collect</button>
                }
                @if (_canReport)
                {
                    <button class="btn btn-secondary" @onclick="() => GoReport(item.Id)">Report</button>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    private List<AssessmentSummaryResponse> _assessments = [];
    private bool _localMode;
    private string? _statusFilter;
    private int? _yearFilter;
    private string? _toast;
    private string _toastType = "info";
    private CreateFormModel _create = new();
    private List<Organization> _orgOptions = [];
    private List<QuestionnaireSummary> _questionnaireOptions = [];
    private bool _canReview;
    private bool _canDashboard;
    private bool _canCollect;
    private bool _canReport;

    private IEnumerable<AssessmentSummaryResponse> Filtered => _assessments
        .Where(a => !_yearFilter.HasValue || a.AssessmentYear == _yearFilter)
        .Where(a => string.IsNullOrWhiteSpace(_statusFilter) || a.Status.Contains(_statusFilter, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(a => a.AssessmentYear);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAdmin = user.IsInRole("Admin");
        var isConsultant = user.IsInRole("Consultant");
        var isRespondent = user.IsInRole("ClientRespondent");

        _canReview = isAdmin || isConsultant;
        _canDashboard = isAdmin || isConsultant;
        _canReport = isAdmin || isConsultant;
        _canCollect = isAdmin || isRespondent;

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        try
        {
            _assessments = (await AssessmentsClient.GetAssessmentsAsync(CancellationToken.None)).ToList();
            _questionnaireOptions = (await QuestionnaireClient.GetAsync(CancellationToken.None)).ToList();

            try
            {
                _orgOptions = (await OrgsClient.GetAsync(CancellationToken.None)).ToList();
            }
            catch (Exception ex) when (IsApiStatusCode(ex.Message, 401) || IsApiStatusCode(ex.Message, 403))
            {
                _orgOptions = _assessments
                    .Select(a => a.OrgId)
                    .Distinct()
                    .OrderBy(id => id)
                    .Select(id => new Organization(id, $"Organization {id}", null, null, null))
                    .ToList();
            }

            InitializeCreateDefaults();
            _localMode = false;
            if (string.Equals(_toastType, "error", StringComparison.OrdinalIgnoreCase))
            {
                _toast = null;
                _toastType = "info";
            }
        }
        catch (Exception ex)
        {
            _assessments = [];
            _orgOptions = [];
            _questionnaireOptions = [];

            if (IsApiUnavailableOrAccessIssue(ex.Message))
            {
                _localMode = true;
                _toast = "Could not load assessments from API. Running in local demo mode; created items will be temporary.";
            }
            else
            {
                _toast = $"Could not load assessments. {ex.Message}";
            }
            _toastType = "error";
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_create.Name))
        {
            _toast = "Assessment name is required.";
            _toastType = "error";
            return;
        }

        var duplicateNameExists = _assessments.Any(a => string.Equals(a.Name, _create.Name.Trim(), StringComparison.OrdinalIgnoreCase));
        if (duplicateNameExists)
        {
            _toast = "An assessment with the same name already exists.";
            _toastType = "error";
            return;
        }

        Guid orgId;
        Guid questionnaireId;

        if (_localMode)
        {
            orgId = Guid.TryParse(_create.OrgIdText, out var parsedOrgId) ? parsedOrgId : Guid.NewGuid();
            questionnaireId = Guid.TryParse(_create.QuestionnaireIdText, out var parsedQuestionnaireId) ? parsedQuestionnaireId : Guid.NewGuid();
        }
        else if (!Guid.TryParse(_create.OrgIdText, out orgId) || !Guid.TryParse(_create.QuestionnaireIdText, out questionnaireId))
        {
            _toast = "Please select an Organization and Questionnaire.";
            _toastType = "error";
            return;
        }

        try
        {
            if (_localMode)
            {
                AddLocalAssessment(_create.Name, _create.AssessmentYear, orgId, questionnaireId);
                return;
            }

            await AssessmentsClient.CreateAsync(new CreateAssessmentRequest(orgId, questionnaireId, _create.AssessmentYear, _create.Name), CancellationToken.None);
            _toast = "Assessment created.";
            _toastType = "success";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            if (IsApiUnavailableOrAccessIssue(ex.Message))
            {
                _localMode = true;
                AddLocalAssessment(_create.Name, _create.AssessmentYear, orgId, questionnaireId);
                return;
            }

            _toast = ex.Message;
            _toastType = "error";
        }
    }

    private void AddLocalAssessment(string name, int year, Guid orgId, Guid questionnaireId)
    {
        _assessments.Insert(0, new AssessmentSummaryResponse(
            Guid.NewGuid(),
            orgId,
            name,
            year,
            "Draft",
            questionnaireId,
            Guid.Parse("00000000-0000-0000-0000-000000000123"),
            DateTimeOffset.UtcNow));

        _toast = "Assessment created in local demo mode (not persisted to API).";
        _toastType = "success";
    }

    private void InitializeCreateDefaults()
    {
        if (string.IsNullOrWhiteSpace(_create.OrgIdText) && _orgOptions.Count > 0)
        {
            _create.OrgIdText = _orgOptions[0].Id.ToString();
        }

        if (string.IsNullOrWhiteSpace(_create.QuestionnaireIdText) && _questionnaireOptions.Count > 0)
        {
            _create.QuestionnaireIdText = _questionnaireOptions[0].Id.ToString();
        }
    }

    private static bool IsApiUnavailableOrAccessIssue(string message)
        => IsApiStatusCode(message, 401)
           || IsApiStatusCode(message, 403)
           || IsApiStatusCode(message, 404)
           || message.Contains("actively refused", StringComparison.OrdinalIgnoreCase)
           || message.Contains("No connection could be made", StringComparison.OrdinalIgnoreCase)
           || message.Contains("connection refused", StringComparison.OrdinalIgnoreCase)
           || message.Contains("An error occurred while sending the request", StringComparison.OrdinalIgnoreCase);

    private static bool IsApiStatusCode(string message, int statusCode)
        => message.Contains($"API request failed ({statusCode})", StringComparison.OrdinalIgnoreCase);

    private void GoReview(Guid id)
    {
        if (_localMode)
        {
            _toast = "Review is unavailable in local demo mode.";
            _toastType = "info";
            return;
        }

        NavigationManager.NavigateTo($"/assessments/{id}/review");
    }

    private void GoDashboard(Guid id)
    {
        if (_localMode)
        {
            _toast = "Dashboard is unavailable in local demo mode.";
            _toastType = "info";
            return;
        }

        NavigationManager.NavigateTo($"/assessments/{id}/dashboard");
    }

    private void GoCollect(Guid id)
    {
        if (_localMode)
        {
            _toast = "Collection is unavailable in local demo mode.";
            _toastType = "info";
            return;
        }

        NavigationManager.NavigateTo($"/assessments/{id}/collect");
    }

    private void GoReport(Guid id)
    {
        if (_localMode)
        {
            _toast = "Report is unavailable in local demo mode.";
            _toastType = "info";
            return;
        }

        NavigationManager.NavigateTo($"/assessments/{id}/dashboard?report=true");
    }

    private sealed class CreateFormModel
    {
        public string Name { get; set; } = "New Assessment";
        public string OrgIdText { get; set; } = string.Empty;
        public string QuestionnaireIdText { get; set; } = string.Empty;
        public int AssessmentYear { get; set; } = DateTime.UtcNow.Year;
    }
}
