@page "/"
@attribute [Authorize]
@inject AuthClient AuthClient

<PageTitle>Home</PageTitle>

<h1>IAM Maturity Studio</h1>

@if (_me is null)
{
    <p>Loading profile...</p>
}
else
{
    <p><strong>User:</strong> @_me.Name (@_me.Email)</p>
    <p><strong>Roles:</strong> @string.Join(", ", _me.Roles)</p>

    <ul>
        @if (HasAnyRole("ClientRespondent", "Admin"))
        {
            <li><NavLink href="/assessments">My Assessments</NavLink></li>
        }
        @if (HasAnyRole("Consultant", "Admin"))
        {
            <li><NavLink href="/assessments">Assessments / Dashboard</NavLink></li>
        }
        @if (HasAnyRole("Admin"))
        {
            <li><NavLink href="/admin">Admin Settings</NavLink></li>
        }
    </ul>
}

@code {
    private MeResponse? _me;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _me = await AuthClient.GetMeAsync(CancellationToken.None);
        }
        catch
        {
            _me = new MeResponse(Guid.Empty, "Unavailable", "n/a", Array.Empty<string>(), Array.Empty<Guid>());
        }
    }

    private bool HasAnyRole(params string[] roles)
    {
        if (_me is null)
        {
            return false;
        }

        return roles.Any(r => _me.Roles.Contains(r, StringComparer.OrdinalIgnoreCase));
    }
}
