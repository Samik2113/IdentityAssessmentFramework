<fieldset class="level-selector" aria-label="Select maturity level">
    <legend class="sr-only">Maturity Level</legend>
    @foreach (var level in Levels)
    {
        <button type="button"
                class="level-btn @(Value == level ? "active" : string.Empty)"
                @onclick="() => Select(level)"
                @onkeydown="e => HandleKey(e, level)"
                disabled="@Disabled"
                aria-pressed="@(Value == level)">
            @level
        </button>
    }
</fieldset>

@code {
    private static readonly string[] Levels = ["Manual", "Partial", "Fully", "NA"];

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Task Select(string level) => ValueChanged.InvokeAsync(level);

    private Task HandleKey(KeyboardEventArgs args, string level)
    {
        if (args.Key is "Enter" or " ")
        {
            return Select(level);
        }

        return Task.CompletedTask;
    }
}
